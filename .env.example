# ─── RunSound environment variables ───────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
BASE_URL=https://your-app.up.railway.app   # your Railway public URL, or custom domain
NODE_ENV=production

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...              # service role key (never expose to frontend)
# SUPABASE_ANON_KEY=eyJ...              # only needed if not using service role

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# IMAGE_MODEL=gpt-image-1.5            # change to gpt-image-2 once org verified

# ── Postiz ────────────────────────────────────────────────────────────────────
POSTIZ_API_KEY=...                      # from postiz.com → API settings
# POSTING_PROVIDER=postiz              # postiz | tiktok (switch when OAuth approved)

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...                   # from resend.com
EMAIL_FROM=RunSound <hello@runsound.fm> # must match a verified Resend domain

# ── Scheduler ─────────────────────────────────────────────────────────────────
CRON_SCHEDULE=0 3 * * *                 # 3:00 AM daily
TZ=Europe/Stockholm                     # your timezone
NOTIFY_EMAIL=your@email.com             # where to send failure alerts

# ── Thresholds (LarryBrain diagnosis) ────────────────────────────────────────
# HIGH_VIEWS_THRESHOLD=5000
# HIGH_CLICKS_THRESHOLD=10

# ── Campaigns directory (multi-artist) ───────────────────────────────────────
# CAMPAIGNS_DIR=/app/campaigns          # default: ./campaigns
