{
  "name": "runsound",
  "version": "1.0.0",
  "description": "Automated TikTok marketing pipeline for music artists",
  "main": "index.js",
  "scripts": {
    "onboard": "node scripts/onboarding.js --validate --config runsound-marketing/config.json",
    "init": "node scripts/onboarding.js --init --dir runsound-marketing",
    "optimize": "node scripts/optimize-strategy.js --config runsound-marketing/config.json",
    "research": "node scripts/research-trends.js --config runsound-marketing/config.json",
    "library": "node scripts/build-image-library.js --config runsound-marketing/config.json",
    "pick": "node scripts/pick-slides.js --config runsound-marketing/config.json --output runsound-marketing/posts/latest",
    "generate": "node scripts/pick-slides.js --config runsound-marketing/config.json --output runsound-marketing/posts/latest",
    "texts": "node scripts/generate-texts.js --config runsound-marketing/config.json --output runsound-marketing/posts/latest",
    "whisper": "node scripts/whisper-sync.js --config runsound-marketing/config.json",
    "overlay": "node scripts/add-text-overlay.js --input runsound-marketing/posts/latest --config runsound-marketing/config.json --texts runsound-marketing/posts/latest/texts.json",
    "assemble": "node scripts/assemble-video.js --input runsound-marketing/posts/latest --config runsound-marketing/config.json",
    "strip": "node scripts/strip-audio.js --input runsound-marketing/posts/latest",
    "post": "node scripts/post-to-tiktok.js --input runsound-marketing/posts/latest --config runsound-marketing/config.json",
    "smart-link": "node smart-link/server.js",
    "analytics": "node scripts/check-analytics.js --config runsound-marketing/config.json --days 3 --connect",
    "report": "node scripts/daily-report.js --config runsound-marketing/config.json --days 3",
    "usage": "node scripts/check-plan-usage.js --config runsound-marketing/config.json --action status",
    "pay-swap": "node scripts/check-plan-usage.js --config runsound-marketing/config.json --action pay-per-swap",
    "all-campaigns": "node scripts/run-all-campaigns.js --campaigns campaigns.json",
    "all-campaigns:texts": "node scripts/run-all-campaigns.js --campaigns campaigns.json --step texts",
    "all-campaigns:overlay": "node scripts/run-all-campaigns.js --campaigns campaigns.json --step overlay",
    "all-campaigns:post": "node scripts/run-all-campaigns.js --campaigns campaigns.json --step post"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.53",
    "fluent-ffmpeg": "^2.1.3",
    "ffmpeg-static": "^5.2.0",
    "openai": "^4.47.0",
    "@supabase/supabase-js": "^2.43.0",
    "form-data": "^4.0.0",
    "node-fetch": "^3.3.2",
    "dotenv": "^16.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
