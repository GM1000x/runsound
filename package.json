{
  "name": "runsound",
  "version": "1.0.0",
  "description": "Automated TikTok marketing pipeline for music artists",
  "main": "index.js",
  "scripts": {
    "optimize": "node optimize-strategy.js --config runsound-marketing/config.json",
    "learn": "node learn.js --config runsound-marketing/config.json",
    "learn:deep": "node learn.js --config runsound-marketing/config.json --days 60",
    "library": "node build-image-library.js --config runsound-marketing/config.json",
    "pick": "node pick-slides.js --config runsound-marketing/config.json --output runsound-marketing/posts/latest",
    "generate": "node pick-slides.js --config runsound-marketing/config.json --output runsound-marketing/posts/latest",
    "texts": "node generate-texts.js --config runsound-marketing/config.json --output runsound-marketing/posts/latest",
    "overlay": "node add-text-overlay.js --input runsound-marketing/posts/latest --config runsound-marketing/config.json --texts runsound-marketing/posts/latest/texts.json",
    "post": "node post-to-tiktok.js --input runsound-marketing/posts/latest --config runsound-marketing/config.json",
    "all-campaigns": "node run-all-campaigns.js --campaigns campaigns.json",
    "all-campaigns:texts": "node run-all-campaigns.js --campaigns campaigns.json --step texts",
    "all-campaigns:overlay": "node run-all-campaigns.js --campaigns campaigns.json --step overlay",
    "all-campaigns:post": "node run-all-campaigns.js --campaigns campaigns.json --step post",
    "scheduler": "node scheduler.js",
    "scheduler:now": "node scheduler.js --run-now",
    "scheduler:dry": "node scheduler.js --dry-run",
    "server": "node api/server.js",
    "dev": "nodemon api/server.js",
    "smart-link": "node api/server.js"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.53",
    "fluent-ffmpeg": "^2.1.3",
    "ffmpeg-static": "^5.2.0",
    "openai": "^4.47.0",
    "@supabase/supabase-js": "^2.43.0",
    "form-data": "^4.0.0",
    "node-fetch": "^3.3.2",
    "node-cron": "^3.0.3",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
